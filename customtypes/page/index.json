{
  "format": "page",
  "id": "page",
  "label": "Side",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "URL Sti (f.eks. om-os)"
        }
      },
      "parent_page": {
        "type": "Link",
        "config": {
          "label": "Forældre side",
          "select": "document",
          "repeat": false,
          "customtypes": ["page"]
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {}
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "SEO titel",
          "placeholder": "Vises i Google og i browser-fanen"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "SEO beskrivelse",
          "placeholder": "Den lille tekst der vises under linket i Google"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "label": "Billede (Sociale Medier)",
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "thumbnails": []
        },
        "type": "Image"
      },
      "noindex": {
        "type": "Boolean",
        "config": {
          "label": "Skjul siden fra Google (noindex)",
          "placeholder_false": "Synlig i Google",
          "placeholder_true": "Skjult fra Google",
          "default_value": false
        }
      },
      "canonical_override": {
        "type": "Text",
        "config": {
          "label": "Canonical URL (avanceret)",
          "placeholder": "Kun hvis siden skal pege på en anden URL i Google"
        }
      }
    }
  }
}
