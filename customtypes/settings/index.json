{
  "format": "custom",
  "id": "settings",
  "label": "Indstillinger",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "force_lang_prefix": {
        "type": "Boolean",
        "config": {
          "label": "Tving sprog i URL? (fx /da-dk)",
          "placeholder_false": "Nej",
          "placeholder_true": "Ja",
          "default_value": false
        }
      },
      "redirects": {
        "type": "Group",
        "config": {
          "label": "Viderestillinger",
          "repeat": true,
          "fields": {
            "from_url": {
              "type": "Text",
              "config": {
                "label": "Fra URL",
                "placeholder": "f.eks. /sommer"
              }
            },
            "to_url": {
              "type": "Text",
              "config": {
                "label": "Til URL",
                "placeholder": "f.eks. /tilbud"
              }
            },
            "redirect_type": {
              "type": "Select",
              "config": {
                "label": "Hvorfor laver du dette link?",
                "placeholder": "",
                "options": [
                  "301 (Siden er slettet/flyttet for altid)",
                  "307 (Dette er blot en midlertidig genvej)"
                ],
                "default_value": "301 (Siden er slettet/flyttet for altid)"
              }
            }
          }
        }
      },
      "color_light": {
        "type": "Color",
        "config": {
          "label": "Lys farve",
          "placeholder": ""
        }
      },
      "color_dark": {
        "type": "Color",
        "config": {
          "label": "Mørk farve",
          "placeholder": ""
        }
      },
      "color_primary": {
        "type": "Color",
        "config": {
          "label": "Primær brandfarve",
          "placeholder": ""
        }
      },
      "color_secondary": {
        "type": "Color",
        "config": {
          "label": "Sekundær brandfarve",
          "placeholder": ""
        }
      },
      "layout_width": {
        "type": "Select",
        "config": {
          "label": "Layoutbredde",
          "placeholder": "Bredden på dit hjemmesideindhold",
          "options": [
            "Klassisk (1200px)",
            "Standard (1280px)",
            "Moderne (1440px)",
            "Ekspansiv (1664px)",
            "Cinematic (1920px)"
          ]
        }
      },
      "border_radius": {
        "type": "Select",
        "config": {
          "label": "Hjørner / radius",
          "placeholder": "Hvor skape eller bløde kanterne skal være på fx kasser og billeder",
          "options": [
            "Skarpe hjørner (0px)",
            "Lille afrunding (4px)",
            "Standard (8px)",
            "Blød (16px)",
            "Pilleformet (Fuld radius)"
          ]
        }
      },
      "font_select": {
        "type": "Select",
        "config": {
          "label": "Skrifttype (Anbefalet - Hurtig)",
          "placeholder": "Vælg en optimeret skrifttype",
          "options": [
            "System standard",
            "Montserrat",
            "Rethink Sans",
            "Comfortaa",
            "Poppins",
            "Abel",
            "Roboto",
            "Open Sans",
            "Inter"
          ],
          "default_value": "System standard"
        }
      },
      "custom_font_input": {
        "type": "Text",
        "config": {
          "label": "Avanceret skrifttype (Bunny Fonts)",
          "placeholder": "Navn fra fonts.bunny.net (f.eks. \"Playfair Display\"). Dette felt overstyrer valget ovenfor."
        }
      }
    }
  }
}
